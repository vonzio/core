FROM node:22-slim

# Build tools for native modules (better-sqlite3, bcrypt) +
# procps so `tsx watch` can call `ps` to enumerate child PIDs on reload —
# node:22-slim doesn't ship it.
RUN apt-get update && apt-get install -y python3 make g++ procps && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files for dependency install
COPY package.json package-lock.json tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/core-server/package.json packages/core-server/
COPY packages/dashboard/package.json packages/dashboard/
COPY packages/widget/package.json packages/widget/
COPY agent-runner/package.json agent-runner/

# Install all dependencies. Using `npm install` (not `npm ci`) because the
# lockfile is generated on macOS and `npm ci` triggers the cross-platform
# optional-deps bug (https://github.com/npm/cli/issues/4828) where the
# linux-arm64/linux-x64 native bindings for @tailwindcss/oxide (and any
# other Rust-bound packages) silently fail to install. `npm install` is
# forgiving about this and pulls the correct platform variant. Lockfile
# strictness is enforced by the prod image (Dockerfile.server).
RUN npm install

# Source code is volume-mounted at runtime — no COPY of src
EXPOSE 3000 5173
