FROM node:22-slim

# Build tools for native modules (better-sqlite3, bcrypt) +
# procps so `tsx watch` can call `ps` to enumerate child PIDs on reload —
# node:22-slim doesn't ship it.
RUN apt-get update && apt-get install -y python3 make g++ procps && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package manifests only — NOT package-lock.json. The lockfile is
# typically generated on the host (macOS arm64 for most dev installs);
# npm's optional-deps bug (https://github.com/npm/cli/issues/4828) means
# `npm install` inside the linux container silently honors the lockfile's
# "wanted: darwin-arm64" + "skipped: linux-*" entries for Rust-native
# packages like @tailwindcss/oxide. The dashboard then crashes on boot
# with "Cannot find native binding."
#
# Resolution: skip the host lockfile in the dev image. npm install
# generates a fresh container-local lockfile with the right platform
# variants. Slower first build, always works. Prod image (Dockerfile.server)
# can use the committed lockfile because it's built in CI on Linux.
COPY package.json tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/plugin-api/package.json packages/plugin-api/
# Plugin manifests only -- dev image bind-mounts the source tree at
# runtime so we just need the workspace symlinks resolved at install.
COPY packages/plugins/ packages/plugins/
COPY packages/core-server/package.json packages/core-server/
COPY packages/dashboard/package.json packages/dashboard/
COPY packages/widget/package.json packages/widget/
COPY agent-runner/package.json agent-runner/

RUN npm install

# Source code is volume-mounted at runtime — no COPY of src
EXPOSE 3000 5173
