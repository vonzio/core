{
  "$schema": "vonzio.brand.tokens.v1",
  "name": "Vonzio · Sodium",
  "description": "Brand tokens for Vonzio. Two surfaces (Paper + Carbon) share one Sodium accent.",
  "color": {
    "brand": {
      "sodium":      { "value": "#FF5722", "role": "Primary accent. Same on every surface." },
      "sodium-soft": { "value": "#FF7849", "role": "Hover, dark-mode pulse." },
      "sodium-deep": { "value": "#E64A1A", "role": "Pressed / active." },
      "graphite":    { "value": "#0E1116", "role": "Brand neutral. Foreground on Paper, background on Carbon." },
      "paper":       { "value": "#FAFAF7", "role": "Default page surface." }
    },
    "status": {
      "ok":   { "value": "#16A34A" },
      "warn": { "value": "#F59E0B" },
      "fail": { "value": "#DC2626" },
      "info": { "value": "#2563EB" }
    },
    "surface": {
      "paper": {
        "page":         "#FAFAF7",
        "card":         "#FFFFFF",
        "mute":         "#F0EEE8",
        "border":       "#E8E6DF",
        "border-strong":"#D6D2C7",
        "ink":          "#0E1116",
        "ink-2":        "#2A2F38",
        "ink-3":        "#3A3A42",
        "muted":        "#6B6B73",
        "muted-2":      "#9B9BA3"
      },
      "carbon": {
        "page":         "#0A0E14",
        "card":         "#13181F",
        "mute":         "#0F141A",
        "border":       "#1F2630",
        "border-strong":"#2A323D",
        "ink":          "#E6E9EE",
        "ink-2":        "#C8CDD5",
        "ink-3":        "#A8B0BC",
        "muted":        "#7A8290",
        "muted-2":      "#5A6270"
      }
    }
  },
  "type": {
    "family": {
      "sans":  "'DM Sans', system-ui, sans-serif",
      "serif": "'Instrument Serif', Georgia, serif",
      "mono":  "'DM Mono', ui-monospace, monospace"
    },
    "scale": {
      "display":   { "size": "clamp(48px, 6.4vw, 96px)", "weight": 600, "tracking": "-0.035em", "leading": 1.05 },
      "h1":        { "size": "clamp(36px, 4.4vw, 64px)", "weight": 600, "tracking": "-0.03em",  "leading": 1.05 },
      "h2":        { "size": "clamp(24px, 2.4vw, 32px)", "weight": 600, "tracking": "-0.02em",  "leading": 1.1 },
      "h3":        { "size": "20px", "weight": 600, "tracking": "-0.01em", "leading": 1.2 },
      "body":      { "size": "16px", "weight": 400, "tracking": "0",       "leading": 1.55 },
      "body-sm":   { "size": "14px", "weight": 400, "tracking": "0",       "leading": 1.5 },
      "caption":   { "size": "13px", "weight": 400, "tracking": "0",       "leading": 1.4 },
      "eyebrow":   { "size": "12px", "weight": 500, "tracking": "0.18em", "leading": 1.2, "case": "upper", "family": "mono" },
      "mono-sm":   { "size": "12px", "weight": 500, "tracking": "0.04em", "leading": 1.4, "family": "mono" }
    }
  },
  "space": {
    "0": "0px",  "1": "4px",  "2": "8px",  "3": "12px",
    "4": "16px", "5": "20px", "6": "24px", "7": "32px",
    "8": "40px", "9": "48px", "10": "64px","11": "80px",
    "12": "96px","13": "128px"
  },
  "radius": {
    "none": "0",
    "sm":   "4px",
    "md":   "8px",
    "lg":   "12px",
    "xl":   "14px",
    "2xl":  "20px",
    "pill": "999px"
  },
  "shadow": {
    "paper": {
      "sm": "0 1px 2px rgba(14,17,22,.04)",
      "md": "0 4px 16px -6px rgba(14,17,22,.10)",
      "lg": "0 24px 64px -24px rgba(14,17,22,.18)"
    },
    "carbon": {
      "sm": "0 1px 2px rgba(0,0,0,.4)",
      "md": "0 4px 16px -6px rgba(0,0,0,.6)",
      "lg": "0 24px 64px -24px rgba(0,0,0,.8)"
    }
  },
  "motion": {
    "fast":   "120ms",
    "base":   "180ms",
    "slow":   "320ms",
    "ease":   "cubic-bezier(.2,.7,.2,1)"
  }
}
