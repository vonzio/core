# vonzio environment template
#
# Copy to .env and fill in. See docs/SELF_HOST.md for the full reference.
# Three REQUIRED secrets: ENCRYPTION_KEY, BETTER_AUTH_SECRET,
# POSTGRES_PASSWORD. compose hard-fails at startup if any is missing.
# Everything else has a sensible default for single-user OSS mode.

# ─── REQUIRED ──────────────────────────────────────────────────────────────
# 32+ random characters each. Generate with:
#   openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
ENCRYPTION_KEY=
BETTER_AUTH_SECRET=
# Postgres superuser password for the compose-managed postgres container.
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# ─── Database ──────────────────────────────────────────────────────────────
# For HOST mode (not compose). The compose stack derives DATABASE_URL
# from POSTGRES_PASSWORD above and ignores this line.
DATABASE_URL=postgres://vonzio:vonzio_dev@localhost:5432/vonzio

# ─── Server ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
PORT=3000
HOST=0.0.0.0
# Public URL where the dashboard is reachable. For OSS the default is
# localhost:5173 (vite dev server, exposed by docker-compose.dev.yml).
# Change to your real domain in production.
BETTER_AUTH_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Single-user OSS. Set to "true" only if you wire your own multi-tenant overlay.
REGISTRATION_ENABLED=false

# ─── Agents / Docker ───────────────────────────────────────────────────────
DOCKER_ENABLED=true
AGENT_IMAGE=vonzio-agent:latest

# ─── Optional: email (Resend) ──────────────────────────────────────────────
# Without this, the "Forgot password" link is hidden from /login.
# RESEND_API_KEY=
# EMAIL_FROM=vonzio <noreply@example.com>

# ─── Optional: Ollama Cloud surface ────────────────────────────────────────
# Set to "true" to show Ollama Cloud as a credential option in /onboarding.
# OLLAMA_ENABLED=true

# ─── Optional: OAuth login providers (Better Auth social sign-in) ──────────
# Fill in both client id and secret per provider to enable.
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GITHUB_CLIENT_ID=
# AUTH_GITHUB_CLIENT_SECRET=

# ─── Optional: Git provider OAuth (for agent repo access) ──────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=
# BITBUCKET_CLIENT_ID=
# BITBUCKET_CLIENT_SECRET=

# ─── Optional: Slack integration ───────────────────────────────────────────
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=

# ─── Optional: Telegram bot ────────────────────────────────────────────────
# PLATFORM_TELEGRAM_BOT_TOKEN=
# PLATFORM_TELEGRAM_WEBHOOK_SECRET=

# ─── Optional: Gmail integration ───────────────────────────────────────────
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=

# ─── Optional: Teller (banking) ────────────────────────────────────────────
# TELLER_APP_ID=
# TELLER_CERT_PATH=
# TELLER_KEY_PATH=
# TELLER_SIGNING_PUBKEY=
# TELLER_ENVIRONMENT=sandbox

# ─── Optional: Cloudflare Turnstile (signup captcha — only matters if
# REGISTRATION_ENABLED=true) ───────────────────────────────────────────────
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
